# Edge profile (<128 MB RAM, minimal footprint)
MAVERICK_CONTAINER_NAME=maverick-edge
MAVERICK_IMAGE=ghcr.io/antonygiomarxdev/maverick:latest
MAVERICK_HTTP_PORT=8080
MAVERICK_UDP_PORT=1700

MAVERICK_STORAGE_PROFILE=extreme
MAVERICK_LOG_FILTER=maverick_core=info
MAVERICK_DB_PATH=/var/lib/maverick/maverick.db

# Conservative limits for constrained hardware
MAVERICK_EVENT_BUS_CAPACITY=64
MAVERICK_UDP_MAX_DATAGRAM_SIZE=2048
