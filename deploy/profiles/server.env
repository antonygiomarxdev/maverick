# Server profile (cloud VM / dedicated server)
MAVERICK_CONTAINER_NAME=maverick-server
MAVERICK_IMAGE=ghcr.io/antonygiomarxdev/maverick:latest
MAVERICK_HTTP_PORT=8080
MAVERICK_UDP_PORT=1700

MAVERICK_STORAGE_PROFILE=high
MAVERICK_LOG_FILTER=maverick_core=info
MAVERICK_DB_PATH=/var/lib/maverick/maverick.db

# Higher throughput and buffering
MAVERICK_EVENT_BUS_CAPACITY=1024
MAVERICK_UDP_MAX_DATAGRAM_SIZE=8192
