# Gateway profile (Raspberry Pi 4 / small x86)
MAVERICK_CONTAINER_NAME=maverick-gateway
MAVERICK_IMAGE=ghcr.io/antonygiomarxdev/maverick:latest
MAVERICK_HTTP_PORT=8080
MAVERICK_UDP_PORT=1700

MAVERICK_STORAGE_PROFILE=auto
MAVERICK_LOG_FILTER=maverick_core=info
MAVERICK_DB_PATH=/var/lib/maverick/maverick.db

# Balanced defaults
MAVERICK_EVENT_BUS_CAPACITY=256
MAVERICK_UDP_MAX_DATAGRAM_SIZE=4096
